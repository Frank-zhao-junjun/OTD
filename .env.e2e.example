# Copy to .env.e2e.local (gitignored) or merge into .env.local
# Required for Playwright E2E against SAP sandbox (my200967)

SAP_BASE_URL=https://my200967-api.s4hana.sapcloud.cn
SAP_CLIENT=100
SAP_USERNAME=EPC_USER
SAP_PASSWORD=your-sandbox-password

# Portal login (seed user with sapUserId — default: sales 13800000002)
E2E_PHONE=13800000002
E2E_PASSWORD=demo123

# Sandbox sample SalesOrder in 1010/10/00/OR (known: 1–13)
E2E_SALES_ORDER=1

# GitHub Actions: repo secrets SAP_SECRET + E2E_SECRET (multiline KEY=VALUE) — see e2e/README.md

# Optional
# E2E_PORT=5000
# E2E_BASE_URL=http://127.0.0.1:5000
