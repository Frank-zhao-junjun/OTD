/* app.wxss - 全局样式 */
/* SAP Horizon主题色系 */
page {
  background-color: #F5F6F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  color: #1D2D3E;
}

/* 主题色 */
.primary-color {
  color: #0070F2;
}

.primary-bg {
  background-color: #0070F2;
}

/* 文字颜色 */
.text-primary {
  color: #1D2D3E;
}

.text-secondary {
  color: #5F6B7A;
}

.text-muted {
  color: #8B9DAF;
}

/* 状态颜色 */
.success-color {
  color: #4DBB6F;
}

.warning-color {
  color: #E76A4F;
}

.error-color {
  color: #BB0000;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 16px;
  margin: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.card-title {
  font-size: 16px;
  font-weight: 600;
  color: #1D2D3E;
}

/* 表格样式 */
.data-table {
  width: 100%;
  border-collapse: collapse;
}

.table-header {
  background-color: #EAECEE;
  font-weight: 600;
}

.table-cell {
  padding: 12px 8px;
  border-bottom: 1px solid #EAECEE;
  font-size: 13px;
}

.table-row {
  background-color: #FFFFFF;
}

.table-row:active {
  background-color: #F0F2F4;
}

/* 搜索框样式 */
.search-container {
  display: flex;
  align-items: center;
  padding: 12px;
  background-color: #FFFFFF;
  border-bottom: 1px solid #EAECEE;
}

.search-input {
  flex: 1;
  height: 32px;
  padding: 0 12px;
  border: 1px solid #C5CACF;
  border-radius: 4px;
  background-color: #FFFFFF;
}

.search-btn {
  margin-left: 12px;
  padding: 0 16px;
  height: 32px;
  line-height: 32px;
  background-color: #0070F2;
  color: #FFFFFF;
  border-radius: 4px;
}

/* 状态徽章 */
.badge {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
}

.badge-success {
  background-color: #E8F5E9;
  color: #4DBB6F;
}

.badge-warning {
  background-color: #FFF3E0;
  color: #E76A4F;
}

.badge-error {
  background-color: #FFEBEE;
  color: #BB0000;
}

.badge-neutral {
  background-color: #EAECEE;
  color: #5F6B7A;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200px;
}

.empty-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 200px;
  color: #8B9DAF;
}