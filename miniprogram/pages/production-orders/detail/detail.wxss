/* pages/production-orders/detail/detail.wxss */

.detail-container {
  min-height: 100vh;
  background: #F8FAFC;
}

/* ── Loading / Error (复用销售订单详情样式) ──────────── */

.state-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120px;
}

.loading-spinner {
  width: 36px;
  height: 36px;
  border: 3px solid #E2E8F0;
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: po-spin 0.8s linear infinite;
}

@keyframes po-spin { to { transform: rotate(360deg); } }

.loading-text { font-size: 13px; color: #64748B; margin-top: 12px; }

.state-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120px;
}

.error-icon { font-size: 48px; margin-bottom: 16px; }
.error-text { font-size: 14px; color: #64748B; margin-bottom: 20px; }

.retry-btn {
  width: 120px; height: 40px;
  background: #3B82F6; color: #FFFFFF;
  font-size: 14px; border-radius: 8px; border: none;
  display: flex; align-items: center; justify-content: center;
}

.retry-btn::after { border: none; }

/* ── Header ─────────────────────────────────────────── */

.detail-header {
  background: linear-gradient(135deg, #1E3A5F 0%, #1E40AF 100%);
  padding: 20px 16px 24px;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.header-order-no {
  font-size: 18px; font-weight: 700; color: #FFFFFF;
}

.header-badge {
  padding: 3px 10px; border-radius: 12px;
  font-size: 12px; font-weight: 600;
}

.header-meta {
  display: flex; align-items: center; flex-wrap: wrap; gap: 6px;
}

.meta-item { font-size: 12px; color: #93C5FD; }
.meta-sep { font-size: 10px; color: rgba(255,255,255,0.25); }

/* ── KPI Grid 2×2 ───────────────────────────────────── */

.kpi-grid {
  display: flex; flex-wrap: wrap;
  padding: 12px 12px 0; gap: 10px;
  margin-top: -8px;
}

.kpi-card {
  width: calc(50% - 5px);
  background: #FFFFFF; border-radius: 10px;
  padding: 14px 12px; display: flex; align-items: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  position: relative; overflow: hidden;
}

.kpi-card::before {
  content: ''; position: absolute;
  left: 0; top: 8px; bottom: 8px; width: 3px;
  border-radius: 0 3px 3px 0;
}

.kpi-blue::before { background: #0A6ED1; }
.kpi-green::before { background: #107E3E; }
.kpi-orange::before { background: #E9730C; }
.kpi-purple::before { background: #7C3AED; }

.kpi-icon-wrap {
  width: 42px; height: 42px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  margin-right: 10px; flex-shrink: 0;
}

.kpi-icon-blue { background: #EFF6FF; }
.kpi-icon-green { background: #ECFDF5; }
.kpi-icon-orange { background: #FFF7ED; }
.kpi-icon-purple { background: #F5F3FF; }

.kpi-emoji { font-size: 20px; }

.kpi-info { display: flex; flex-direction: column; min-width: 0; }

.kpi-val { font-size: 22px; font-weight: 700; color: #1E293B; line-height: 1.2; }
.kpi-lbl { font-size: 11px; color: #64748B; margin-top: 2px; }
.kpi-un { font-size: 10px; color: #94A3B8; }

/* ── Section ────────────────────────────────────────── */

.section {
  margin: 12px 12px 0;
  background: #FFFFFF; border-radius: 10px;
  padding: 12px 14px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.section-header {
  display: flex; align-items: center; margin-bottom: 10px;
}

.section-title { font-size: 14px; font-weight: 600; color: #475569; }

/* ── Operations ─────────────────────────────────────── */

.op-card {
  padding: 14px 0; border-bottom: 1px solid #F1F5F9;
}

.op-card:last-child { border-bottom: none; }

.op-header {
  display: flex; align-items: center; gap: 8px; margin-bottom: 6px;
}

.op-seq {
  width: 36px; height: 22px;
  background: #EFF6FF; color: #1E40AF;
  font-size: 11px; font-weight: 700; border-radius: 4px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.op-desc { font-size: 14px; font-weight: 600; color: #1E293B; }

.op-meta { margin-bottom: 8px; }

.op-wc { font-size: 12px; color: #64748B; }

.op-dates { margin-bottom: 10px; }

.op-date-row {
  display: flex; gap: 8px; padding: 2px 0;
}

.op-date-label {
  font-size: 11px; color: #94A3B8; min-width: 28px;
}

.op-date-val { font-size: 12px; color: #475569; }

/* 进度条 */
.op-progress-wrap {
  display: flex; align-items: center; gap: 10px; margin-bottom: 8px;
}

.op-progress-bar {
  flex: 1; height: 6px; background: #F1F5F9; border-radius: 3px; overflow: hidden;
}

.op-progress-fill {
  height: 100%; border-radius: 3px; transition: width 0.5s ease;
}

.op-progress-pct { font-size: 13px; font-weight: 700; min-width: 40px; text-align: right; }

.op-yield { display: flex; gap: 16px; }

.yield-text { font-size: 12px; color: #107E3E; font-weight: 500; }
.scrap-text { font-size: 12px; color: #EF4444; font-weight: 500; }

/* ── Components ─────────────────────────────────────── */

.comp-card {
  padding: 12px 0; border-bottom: 1px solid #F1F5F9;
}

.comp-card:last-child { border-bottom: none; }

.comp-header {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;
}

.comp-material { font-size: 14px; font-weight: 600; color: #1E293B; }

.comp-badge {
  padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600;
}

.comp-desc { font-size: 12px; color: #64748B; margin-bottom: 6px; display: block; }

.comp-row {
  display: flex; align-items: center; gap: 6px; margin-bottom: 4px;
}

.comp-qty { font-size: 12px; color: #475569; }
.comp-sep { font-size: 10px; color: #CBD5E1; }
.comp-withdrawn { font-size: 12px; color: #475569; }

.comp-loc { font-size: 11px; color: #94A3B8; }
