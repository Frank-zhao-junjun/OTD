<!-- pages/login/login.wxml -->
<view class="login-container">
  <!-- Logo 区域 -->
  <view class="login-header">
    <view class="login-logo">
      <view class="login-logo-icon">ES</view>
    </view>
    <text class="login-title">OTD助手</text>
    <text class="login-subtitle">SAP ERP 数据查询系统</text>
  </view>

  <!-- 表单 -->
  <view class="login-form">
    <!-- 用户名 -->
    <view class="form-item">
      <view class="form-input-wrap">
        <text class="form-icon">用户</text>
        <input
          class="form-input {{errors.username ? 'form-input-error' : ''}}"
          type="text"
          placeholder="用户名"
          placeholder-class="form-placeholder"
          value="{{username}}"
          bindinput="onUsernameInput"
          maxlength="20"
          auto-focus
        />
      </view>
      <text class="form-error" wx:if="{{errors.username}}">{{errors.username}}</text>
    </view>

    <!-- 密码 -->
    <view class="form-item">
      <view class="form-input-wrap">
        <text class="form-icon">密码</text>
        <input
          class="form-input {{errors.password ? 'form-input-error' : ''}}"
          type="{{showPassword ? 'text' : 'password'}}"
          placeholder="密码"
          placeholder-class="form-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
          maxlength="32"
        />
        <view class="form-suffix" bindtap="onTogglePassword">
          <text>{{showPassword ? '隐藏' : '显示'}}</text>
        </view>
      </view>
      <text class="form-error" wx:if="{{errors.password}}">{{errors.password}}</text>
    </view>

    <!-- 验证码 -->
    <view class="form-item">
      <view class="captcha-row">
        <view class="form-input-wrap captcha-input-wrap">
          <text class="form-icon">验证码</text>
          <input
            class="form-input {{errors.captcha ? 'form-input-error' : ''}}"
            type="number"
            placeholder="验证码"
            placeholder-class="form-placeholder"
            value="{{captcha}}"
            bindinput="onCaptchaInput"
            maxlength="4"
          />
        </view>
        <view class="captcha-display" bindtap="onRefreshCaptcha">
          <image wx:if="{{captchaSvgBase64}}" class="captcha-img" src="{{captchaSvgBase64}}" mode="aspectFit" />
          <text wx:else class="captcha-text">获取中...</text>
          <text class="captcha-hint">点击刷新</text>
        </view>
      </view>
      <text class="form-error" wx:if="{{errors.captcha}}">{{errors.captcha}}</text>
    </view>

    <!-- 登录按钮 -->
    <button
      class="login-btn {{submitting ? 'login-btn-disabled' : ''}}"
      bindtap="onLogin"
      disabled="{{submitting}}"
      loading="{{submitting}}"
    >
      {{submitting ? '登录中...' : '登 录'}}
    </button>

    <!-- 注册入口 -->
    <view class="login-footer">
      <text class="login-footer-text">还没有账号？</text>
      <text class="login-footer-link" bindtap="onGoRegister">去注册 →</text>
    </view>
  </view>
</view>
