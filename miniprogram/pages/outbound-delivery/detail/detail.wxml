<!-- pages/outbound-delivery/detail/detail.wxml -->
<view class="detail-container">

  <view class="state-loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="state-error" wx:elif="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{errorMsg}}</text>
    <button class="retry-btn" bindtap="onRetry">重试</button>
  </view>

  <block wx:else>
    <!-- 头部 -->
    <view class="detail-header">
      <view class="header-top">
        <text class="header-order-no">交货单 {{header.DeliveryDocument}}</text>
        <view class="header-badge" style="background-color: {{header.statusColor}}15; color: {{header.statusColor}};">
          <text>{{header.statusText}}</text>
        </view>
      </view>
      <view class="header-meta">
        <text class="meta-item">{{header.DeliveryDocumentType}}</text>
        <text class="meta-sep">|</text>
        <text class="meta-item">客户 {{header.SoldToParty}}</text>
        <text class="meta-sep">|</text>
        <text class="meta-item">{{header.DeliveryDate}}</text>
        <text class="meta-sep">|</text>
        <text class="meta-item">销售组织 {{header.SalesOrganization}}</text>
      </view>
    </view>

    <!-- 行项目 -->
    <view class="section" wx:if="{{items.length > 0}}">
      <view class="section-header">
        <text class="section-title">📋 行项目 ({{items.length}})</text>
      </view>
      <view class="item-card" wx:for="{{items}}" wx:key="*this">
        <view class="item-header">
          <text class="item-material">{{item.Material}}</text>
        </view>
        <text class="item-desc" wx:if="{{item.DeliveryDocumentItemText}}">{{item.DeliveryDocumentItemText}}</text>
        <view class="item-qty-row">
          <view class="qty-block planned">
            <text class="qty-label">计划</text>
            <text class="qty-value">{{item.PlannedDeliveryQuantity}} {{item.DeliveryQuantityUnit}}</text>
          </view>
          <text class="qty-arrow">→</text>
          <view class="qty-block actual">
            <text class="qty-label">实际</text>
            <text class="qty-value">{{item.ActualDeliveryQuantity}} {{item.DeliveryQuantityUnit}}</text>
          </view>
        </view>
        <view class="item-meta-row">
          <text class="item-meta">过账日期: {{item.ActualGoodsMovementDate}}</text>
          <text class="item-meta">库位: {{item.StorageLocation}}</text>
        </view>
      </view>
    </view>

    <!-- 关联销售订单 -->
    <view class="section" wx:if="{{salesOrder}}">
      <view class="section-header">
        <text class="section-title">📎 关联销售订单</text>
      </view>
      <view class="link-card" bindtap="onTapSalesOrder">
        <text class="link-no">{{salesOrder.SalesOrder}}</text>
        <text class="link-info">查看销售订单详情</text>
        <text class="link-arrow">›</text>
      </view>
    </view>

    <view style="height: 24px;"></view>
  </block>
</view>
