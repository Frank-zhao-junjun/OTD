/* pages/outbound-delivery/detail/detail.wxss */
.detail-container { min-height: 100vh; background: #F8FAFC; }

.state-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 120px; }
.loading-spinner { width: 36px; height: 36px; border: 3px solid #E2E8F0; border-top-color: #3B82F6; border-radius: 50%; animation: od-spin 0.8s linear infinite; }
@keyframes od-spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 13px; color: #64748B; margin-top: 12px; }

.state-error { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 120px; }
.error-icon { font-size: 48px; margin-bottom: 16px; }
.error-text { font-size: 14px; color: #64748B; margin-bottom: 20px; }
.retry-btn { width: 120px; height: 40px; background: #3B82F6; color: #FFF; font-size: 14px; border-radius: 8px; border: none; display: flex; align-items: center; justify-content: center; }
.retry-btn::after { border: none; }

/* Header */
.detail-header { background: linear-gradient(135deg, #1E3A5F 0%, #1E40AF 100%); padding: 20px 16px 24px; }
.header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.header-order-no { font-size: 18px; font-weight: 700; color: #FFF; }
.header-badge { padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
.header-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; }
.meta-item { font-size: 12px; color: #93C5FD; }
.meta-sep { font-size: 10px; color: rgba(255,255,255,0.25); }

/* Section */
.section { margin: 12px 12px 0; background: #FFF; border-radius: 10px; padding: 12px 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.04); }
.section-header { display: flex; align-items: center; margin-bottom: 10px; }
.section-title { font-size: 14px; font-weight: 600; color: #475569; }

/* Items */
.item-card { padding: 12px 0; border-bottom: 1px solid #F1F5F9; }
.item-card:last-child { border-bottom: none; }
.item-header { margin-bottom: 4px; }
.item-material { font-size: 14px; font-weight: 600; color: #1E293B; }
.item-desc { font-size: 12px; color: #64748B; margin-bottom: 8px; display: block; }

.item-qty-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.qty-block { flex: 1; background: #F8FAFC; border-radius: 8px; padding: 8px 10px; display: flex; flex-direction: column; }
.qty-block.planned { border-left: 3px solid #94A3B8; }
.qty-block.actual { border-left: 3px solid #107E3E; }
.qty-label { font-size: 10px; color: #94A3B8; margin-bottom: 2px; }
.qty-value { font-size: 14px; font-weight: 700; color: #1E293B; }
.qty-arrow { font-size: 16px; color: #CBD5E1; flex-shrink: 0; }

.item-meta-row { display: flex; gap: 16px; }
.item-meta { font-size: 11px; color: #94A3B8; }

/* Linked */
.link-card { display: flex; align-items: center; padding: 10px 0; }
.link-card:active { background: #F8FAFC; margin: 0 -14px; padding-left: 14px; padding-right: 14px; }
.link-no { font-size: 14px; font-weight: 600; color: #1E40AF; min-width: 80px; }
.link-info { flex: 1; font-size: 12px; color: #64748B; margin-left: 10px; }
.link-arrow { font-size: 16px; color: #CBD5E1; }
