<!-- pages/index/index.wxml - 首页 Dashboard -->
<view class="dashboard">
  <!-- ShellBar -->
  <view class="shell-bar">
    <view class="shell-left">
      <view class="shell-logo">ES</view>
      <view class="shell-titles">
        <text class="shell-title">OTD助手</text>
        <text class="shell-subtitle">SAP S/4HANA Cloud</text>
      </view>
    </view>
    <view class="shell-search" bindtap="onSearchTap">
      <text class="shell-search-icon">🔍</text>
      <text class="shell-search-text">搜索订单、物料...</text>
    </view>
  </view>

  <!-- KPI 卡片 2×2 -->
  <view class="kpi-grid">
    <view
      class="kpi-card kpi-{{item.color}}"
      wx:for="{{kpis}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onKpiTap"
    >
      <view class="kpi-icon-wrap kpi-icon-{{item.color}}">
        <text class="kpi-emoji">{{item.icon}}</text>
      </view>
      <view class="kpi-info">
        <text class="kpi-value">{{loading ? '—' : item.value}}</text>
        <text class="kpi-label">{{item.label}}</text>
        <text class="kpi-unit">共{{item.value}}{{item.unit}}</text>
      </view>
    </view>
  </view>

  <!-- 最近动态 -->
  <view class="section" wx:if="{{activities.length > 0}}">
    <view class="section-header">
      <text class="section-title">📋 最近动态</text>
    </view>
    <view class="activity-list">
      <view
        class="activity-item activity-{{item.color}}"
        wx:for="{{activities}}"
        wx:key="index"
      >
        <view class="activity-dot"></view>
        <view class="activity-content">
          <text class="activity-text">{{item.text}}</text>
          <text class="activity-meta">{{item.meta}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能模块 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📁 业务交易</text>
    </view>
    <view class="module-grid">
      <view
        class="module-item"
        wx:for="{{businessModules}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="navigateToModule"
      >
        <view class="module-icon" style="background-color: {{item.color}}15;">
          <text class="module-emoji">{{item.icon}}</text>
        </view>
        <text class="module-title">{{item.title}}</text>
        <text class="module-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">📁 主数据</text>
    </view>
    <view class="module-grid">
      <view
        class="module-item"
        wx:for="{{masterModules}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="navigateToModule"
      >
        <view class="module-icon" style="background-color: {{item.color}}15;">
          <text class="module-emoji">{{item.icon}}</text>
        </view>
        <text class="module-title">{{item.title}}</text>
        <text class="module-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 首次加载遮罩 -->
  <view class="loading-overlay" wx:if="{{loading && kpis[0].value === '—'}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
</view>
