/* pages/index/index.wxss - 首页 Dashboard */

.dashboard {
  min-height: 100vh;
  background: #F8FAFC;
  padding-bottom: 20px;
}

/* ── ShellBar ────────────────────────────────────────── */

.shell-bar {
  background: linear-gradient(135deg, #1E3A5F 0%, #1E40AF 100%);
  padding: 16px 16px 20px;
  display: flex;
  flex-direction: column;
}

.shell-left {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.shell-logo {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 700;
  color: #FFFFFF;
  margin-right: 12px;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.shell-titles {
  display: flex;
  flex-direction: column;
}

.shell-title {
  font-size: 18px;
  font-weight: 700;
  color: #FFFFFF;
}

.shell-subtitle {
  font-size: 11px;
  color: #93C5FD;
  margin-top: 2px;
}

.shell-search {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 20px;
  padding: 10px 16px;
}

.shell-search:active {
  background: rgba(255, 255, 255, 0.25);
}

.shell-search-icon {
  font-size: 14px;
  margin-right: 8px;
}

.shell-search-text {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.6);
}

/* ── KPI Grid ────────────────────────────────────────── */

.kpi-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 12px 12px 0;
  gap: 10px;
  margin-top: -8px;
}

.kpi-card {
  width: calc(50% - 5px);
  background: #FFFFFF;
  border-radius: 10px;
  padding: 14px 12px;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.kpi-card:active {
  background: #F8FAFC;
}

.kpi-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8px;
  bottom: 8px;
  width: 3px;
  border-radius: 0 3px 3px 0;
}

.kpi-blue::before { background: #0A6ED1; }
.kpi-green::before { background: #107E3E; }
.kpi-orange::before { background: #E9730C; }
.kpi-purple::before { background: #7C3AED; }

.kpi-icon-wrap {
  width: 42px;
  height: 42px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10px;
  flex-shrink: 0;
}

.kpi-icon-blue { background: #EFF6FF; }
.kpi-icon-green { background: #ECFDF5; }
.kpi-icon-orange { background: #FFF7ED; }
.kpi-icon-purple { background: #F5F3FF; }

.kpi-emoji {
  font-size: 20px;
}

.kpi-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.kpi-value {
  font-size: 22px;
  font-weight: 700;
  color: #1E293B;
  line-height: 1.2;
}

.kpi-label {
  font-size: 11px;
  color: #64748B;
  margin-top: 2px;
}

.kpi-unit {
  font-size: 10px;
  color: #94A3B8;
}

/* ── Section ─────────────────────────────────────────── */

.section {
  padding: 0 12px;
  margin-top: 16px;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #475569;
}

/* ── Activity List ───────────────────────────────────── */

.activity-list {
  background: #FFFFFF;
  border-radius: 10px;
  padding: 4px 12px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.activity-item {
  display: flex;
  align-items: flex-start;
  padding: 12px 0;
  border-bottom: 1px solid #F1F5F9;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-top: 6px;
  margin-right: 10px;
  flex-shrink: 0;
}

.activity-success .activity-dot { background: #22C55E; }
.activity-warning .activity-dot { background: #F59E0B; }
.activity-error .activity-dot { background: #EF4444; }
.activity-info .activity-dot { background: #3B82F6; }

.activity-content {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.activity-text {
  font-size: 13px;
  color: #1E293B;
  line-height: 1.4;
}

.activity-meta {
  font-size: 11px;
  color: #94A3B8;
  margin-top: 2px;
}

/* ── Module Grid ─────────────────────────────────────── */

.module-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.module-item {
  width: calc(25% - 6px);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14px 6px 10px;
  background: #FFFFFF;
  border-radius: 10px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.module-item:active {
  background: #F8FAFC;
}

.module-icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.module-emoji {
  font-size: 22px;
}

.module-title {
  font-size: 12px;
  font-weight: 600;
  color: #1E293B;
}

.module-desc {
  font-size: 9px;
  color: #94A3B8;
  margin-top: 2px;
}

/* ── Loading Overlay ─────────────────────────────────── */

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(248, 250, 252, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-spinner {
  width: 36px;
  height: 36px;
  border: 3px solid #E2E8F0;
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: dash-spin 0.8s linear infinite;
}

@keyframes dash-spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 13px;
  color: #64748B;
  margin-top: 12px;
}
