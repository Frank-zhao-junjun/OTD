/* pages/sales-orders/sales-orders.wxss */
.container { padding-bottom: 20px; }

/* ── Toolbar ───────────────────────────────── */

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6px 12px;
  background-color: #F0F9FF;
}

.filter-hint { flex: 1; }

.hint-text { font-size: 11px; color: #64748B; }

.card-footer {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 8px; padding-top: 8px;
  border-top: 1px solid #F1F5F9;
}

/* ── Table ─────────────────────────────────── */

.table-scroll {
  width: 100%;
}

.table-view {
  min-width: 560px;
}

.table-row {
  display: flex;
  align-items: center;
  border-bottom: 1px solid #F1F5F9;
  padding: 0 12px;
  min-height: 40px;
}

.table-head {
  background: #F8FAFC;
  border-bottom: 2px solid #E2E8F0;
}

.table-head .table-cell {
  font-size: 11px;
  font-weight: 600;
  color: #64748B;
}

.table-cell {
  font-size: 13px;
  color: #1E293B;
  padding: 8px 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.w-order { width: 90px; flex-shrink: 0; }
.w-type  { width: 50px; flex-shrink: 0; }
.w-cust  { width: 90px; flex-shrink: 0; }
.w-date  { width: 95px; flex-shrink: 0; }
.w-amt   { width: 100px; flex-shrink: 0; text-align: right; }
.w-status { width: 75px; flex-shrink: 0; font-weight: 500; }
