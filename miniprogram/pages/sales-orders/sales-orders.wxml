<!--pages/sales-orders/sales-orders.wxml -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <input 
        class="search-input" 
        placeholder="订单号/客户编号/采购单号" 
        value="{{searchQuery}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
    </view>
    <button class="search-btn primary-bg" bindtap="onSearch">查询</button>
    <button class="search-btn default" bindtap="onClear">重置</button>
  </view>

  <!-- 工具栏 -->
  <view class="toolbar">
    <view class="filter-hint">
      <text class="hint-text">默认: OR/1010/10/00</text>
    </view>
    <view-switch mode="{{viewMode}}" bind:change="onViewModeChange"/>
  </view>

  <!-- 结果统计 -->
  <view class="result-header" wx:if="{{totalCount > 0}}">
    <text class="result-count">共 {{totalCount}} 条记录</text>
  </view>

  <!-- 卡片视图 -->
  <view wx:if="{{!loading && orders.length > 0 && viewMode === 'card'}}">
    <block wx:for="{{orders}}" wx:key="SalesOrder">
      <view class="list-card" data-id="{{item.SalesOrder}}" bindtap="onViewDetail">
        <view class="card-header">
          <text class="card-title">{{item.SalesOrder}}</text>
          <text class="card-badge" style="background-color: {{item.OverallSDProcessStatus === 'C' ? '#DCFCE7' : item.OverallSDProcessStatus === 'B' ? '#DBEAFE' : '#FEF3C7'}}; color: {{item.OverallSDProcessStatus === 'C' ? '#166534' : item.OverallSDProcessStatus === 'B' ? '#1E40AF' : '#92400E'}};">
            {{item.OverallSDProcessStatus_text}}
          </text>
        </view>
        <view class="card-body">
          <view class="card-row"><text class="card-label">客户编号</text><text class="card-value">{{item.SoldToParty || '-'}}</text></view>
          <view class="card-row"><text class="card-label">客户采购单</text><text class="card-value">{{item.PurchaseOrderByCustomer || '-'}}</text></view>
          <view class="card-row"><text class="card-label">订单日期</text><text class="card-value">{{item.SalesOrderDate}}</text></view>
        </view>
        <view class="card-footer">
          <text class="card-amount">¥{{item.TotalNetAmount}}</text>
          <text class="card-label">{{item.TransactionCurrency || 'CNY'}}</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 表格视图 -->
  <scroll-view scroll-x wx:if="{{!loading && orders.length > 0 && viewMode === 'table'}}" class="table-scroll">
    <view class="table-view">
      <view class="table-row table-head">
        <text class="table-cell w-order">订单号</text>
        <text class="table-cell w-type">类型</text>
        <text class="table-cell w-cust">客户</text>
        <text class="table-cell w-date">日期</text>
        <text class="table-cell w-amt">金额</text>
        <text class="table-cell w-status">状态</text>
      </view>
      <view class="table-row" wx:for="{{orders}}" wx:key="SalesOrder" data-id="{{item.SalesOrder}}" bindtap="onViewDetail">
        <text class="table-cell w-order">{{item.SalesOrder}}</text>
        <text class="table-cell w-type">{{item.SalesOrderType || 'TA'}}</text>
        <text class="table-cell w-cust">{{item.SoldToParty || '-'}}</text>
        <text class="table-cell w-date">{{item.SalesOrderDate}}</text>
        <text class="table-cell w-amt">¥{{item.TotalNetAmount}}</text>
        <text class="table-cell w-status" style="color: {{item.OverallSDProcessStatus === 'C' ? '#107E3E' : item.OverallSDProcessStatus === 'B' ? '#E9730C' : '#0A6ED1'}};">{{item.OverallSDProcessStatus_text}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-container" wx:if="{{!loading && orders.length === 0}}">
    <text class="empty-text">暂无销售订单数据</text>
  </view>
</view>
