<!--pages/billing-documents/billing-documents.wxml -->
<view class="container">
  <view class="search-bar">
    <view class="search-input-wrap">
      <input class="search-input" placeholder="开票单号/客户编号" value="{{searchQuery}}" bindinput="onSearchInput" bindconfirm="onSearch"/>
    </view>
    <button class="search-btn primary-bg" bindtap="onSearch">查询</button>
    <button class="search-btn default" bindtap="onClear">重置</button>
  </view>

  <view class="toolbar">
    <view class="filter-hint"></view>
    <view-switch mode="{{viewMode}}" bind:change="onViewModeChange"/>
  </view>

  <view class="result-header" wx:if="{{totalCount > 0}}">
    <text class="result-count">共 {{totalCount}} 条记录</text>
  </view>

  <view wx:if="{{!loading && documents.length > 0 && viewMode === 'card'}}">
    <block wx:for="{{documents}}" wx:key="BillingDocument">
      <view class="list-card" bindtap="onViewDetail" data-id="{{item.BillingDocument}}">
        <view class="card-header">
          <text class="card-title">{{item.BillingDocument}}</text>
          <text class="card-badge" style="background-color: {{item.BillingIsCancelled === true ? '#FEE2E2' : '#DCFCE7'}}; color: {{item.BillingIsCancelled === true ? '#991B1B' : '#166534'}};">
            {{item.BillingIsCancelled === true ? '已取消' : '有效'}}
          </text>
        </view>
        <view class="card-body">
          <view class="card-row">
            <text class="card-label">客户</text>
            <text class="card-value">{{item.SoldToParty || '-'}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">开票日期</text>
            <text class="card-value">{{item.BillingDocumentDate}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">类型</text>
            <text class="card-value">{{item.BillingDocumentType || '-'}}</text>
          </view>
        </view>
        <view class="card-footer">
          <text class="card-amount">¥{{item.TotalNetAmount}}</text>
          <text class="card-label">税额: ¥{{item.TotalTaxAmount}}</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 表格视图 -->
  <scroll-view scroll-x wx:if="{{!loading && documents.length > 0 && viewMode === 'table'}}" class="table-scroll">
    <view class="table-view">
      <view class="table-row table-head">
        <view class="table-cell" style="flex:1.5;">开票单号</view>
        <view class="table-cell" style="flex:1.5;">客户</view>
        <view class="table-cell" style="flex:1.5;">开票日期</view>
        <view class="table-cell">类型</view>
        <view class="table-cell" style="flex:1.5;">金额</view>
        <view class="table-cell">状态</view>
      </view>
      <view class="table-row" wx:for="{{documents}}" wx:key="BillingDocument" bindtap="onViewDetail" data-id="{{item.BillingDocument}}">
        <view class="table-cell" style="flex:1.5;">{{item.BillingDocument}}</view>
        <view class="table-cell" style="flex:1.5;">{{item.SoldToParty || '-'}}</view>
        <view class="table-cell" style="flex:1.5;">{{item.BillingDocumentDate}}</view>
        <view class="table-cell">{{item.BillingDocumentType || '-'}}</view>
        <view class="table-cell" style="flex:1.5;">¥{{item.TotalNetAmount}}</view>
        <view class="table-cell">{{item.BillingIsCancelled === true ? '已取消' : '有效'}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty-container" wx:if="{{!loading && documents.length === 0}}">
    <text class="empty-text">暂无开票数据</text>
  </view>
</view>
