<!-- pages/billing-documents/detail/detail.wxml -->
<view class="detail-container">

  <view class="state-loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="state-error" wx:elif="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{errorMsg}}</text>
    <button class="retry-btn" bindtap="onRetry">重试</button>
  </view>

  <block wx:else>
    <!-- 头部 -->
    <view class="detail-header">
      <view class="header-top">
        <text class="header-order-no">开票单 {{header.BillingDocument}}</text>
        <view class="header-badge" style="background-color: {{header.statusColor}}15; color: {{header.statusColor}};">
          <text>{{header.statusText}}</text>
        </view>
      </view>
      <view class="header-meta">
        <text class="meta-item">{{header.BillingDocumentType}}</text>
        <text class="meta-sep">|</text>
        <text class="meta-item">客户 {{header.SoldToParty}}</text>
        <text class="meta-sep">|</text>
        <text class="meta-item">{{header.BillingDocumentDate}}</text>
      </view>
      <text class="header-amount">{{header.TotalNetAmount}}</text>
    </view>

    <!-- 行项目 -->
    <view class="section" wx:if="{{items.length > 0}}">
      <view class="section-header">
        <text class="section-title">📋 行项目 ({{items.length}})</text>
      </view>
      <view class="item-card" wx:for="{{items}}" wx:key="*this">
        <view class="item-header">
          <text class="item-material">{{item.Material}}</text>
          <text class="item-amount">{{item.NetAmount}}</text>
        </view>
        <text class="item-desc" wx:if="{{item.BillingDocumentItemText}}">{{item.BillingDocumentItemText}}</text>
        <text class="item-qty">数量: {{item.BillingQuantity}} {{item.BillingQuantityUnit}}</text>
      </view>
    </view>

    <!-- 关联单据 -->
    <view class="section" wx:if="{{salesOrder || deliveryDoc}}">
      <view class="section-header">
        <text class="section-title">📎 关联单据</text>
      </view>
      <view class="link-card" wx:if="{{salesOrder}}" bindtap="onTapSalesOrder">
        <text class="link-no">销售订单 {{salesOrder.SalesOrder}}</text>
        <text class="link-info">查看详情</text>
        <text class="link-arrow">›</text>
      </view>
      <view class="link-card" wx:if="{{deliveryDoc}}" bindtap="onTapDelivery">
        <text class="link-no">交货单 {{deliveryDoc.DeliveryDocument}}</text>
        <text class="link-info">查看详情</text>
        <text class="link-arrow">›</text>
      </view>
    </view>

    <view style="height: 24px;"></view>
  </block>
</view>
