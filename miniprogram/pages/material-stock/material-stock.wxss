/* pages/material-stock/material-stock.wxss */
.container { padding-bottom: 20px; }
.filter-hint { padding: 6px 12px; background-color: #F0FDF4; }
.hint-text { font-size: 11px; color: #64748B; }

.view-toggle {
  display: flex;
  padding: 8px 12px;
  gap: 8px;
}

.toggle-btn {
  flex: 1;
  text-align: center;
  padding: 8px;
  border-radius: 6px;
  font-size: 13px;
  background-color: #F1F5F9;
  color: #64748B;
  font-weight: 500;
}

.toggle-btn.active {
  background-color: #1E40AF;
  color: #FFFFFF;
}
