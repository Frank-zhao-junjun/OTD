<!--pages/material-stock/material-stock.wxml -->
<view class="container">
  <view class="search-bar">
    <view class="search-input-wrap">
      <input class="search-input" placeholder="输入物料编号" value="{{searchQuery}}" bindinput="onSearchInput" bindconfirm="onSearch"/>
    </view>
    <button class="search-btn primary-bg" bindtap="onSearch">查询</button>
    <button class="search-btn default" bindtap="onClear">重置</button>
  </view>

  <view class="filter-hint">
    <text class="hint-text">范围: 工厂 {{plant}} + 库位 {{storageLocation}}</text>
  </view>

  <!-- 视图切换 -->
  <view class="view-toggle">
    <view class="toggle-btn {{viewMode === 'summary' ? 'active' : ''}}" data-mode="summary" bindtap="switchView">汇总视图</view>
    <view class="toggle-btn {{viewMode === 'detail' ? 'active' : ''}}" data-mode="detail" bindtap="switchView">明细视图</view>
  </view>

  <!-- 汇总视图 -->
  <view wx:if="{{viewMode === 'summary'}}">
    <view class="result-header">
      <text class="result-count">共 {{summary.length}} 种物料</text>
    </view>
    <block wx:for="{{summary}}" wx:key="Material">
      <view class="list-card">
        <view class="card-header">
          <text class="card-title">{{item.Material}}</text>
        </view>
        <view class="card-body">
          <view class="card-row">
            <text class="card-label">描述</text>
            <text class="card-value">{{item.MaterialName}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">可用数量</text>
            <text class="card-value" style="font-weight:600; color:#059669;">{{item.totalQty.toFixed(3)}} {{item.unit}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">批次数</text>
            <text class="card-value">{{item.batches}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 明细视图 -->
  <view wx:if="{{viewMode === 'detail'}}">
    <view class="result-header">
      <text class="result-count">共 {{totalCount}} 条记录</text>
    </view>
    <block wx:for="{{stocks}}" wx:key="Material">
      <view class="list-card">
        <view class="card-header">
          <text class="card-title">{{item.Material}}</text>
          <text class="card-badge" style="background-color: {{item.StockType === '01' ? '#DCFCE7' : item.StockType === '02' ? '#FEF3C7' : '#FEE2E2'}}; color: {{item.StockType === '01' ? '#166534' : item.StockType === '02' ? '#92400E' : '#991B1B'}};">
            {{item.StockType === '01' ? '非限制' : item.StockType === '02' ? '质检' : '冻结'}}
          </text>
        </view>
        <view class="card-body">
          <view class="card-row">
            <text class="card-label">批次</text>
            <text class="card-value">{{item.Batch || '-'}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">数量</text>
            <text class="card-value">{{item.MatlWrhsStkQtyInMatlBaseUnit || '0'}} {{item.BaseUnit || ''}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty-container" wx:if="{{!loading && stocks.length === 0}}">
    <text class="empty-text">暂无库存数据</text>
  </view>
</view>
