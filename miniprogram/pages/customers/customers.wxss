.container { padding-bottom: 20px; }
.toolbar { display: flex; align-items: center; justify-content: space-between; padding: 6px 12px; background-color: #F0F9FF; }
.filter-hint { flex: 1; }
.hint-text { font-size: 11px; color: #64748B; }
.table-scroll { width: 100%; }
.table-view { min-width: 480px; }
.table-row { display: flex; align-items: center; border-bottom: 1px solid #F1F5F9; padding: 0 12px; min-height: 40px; }
.table-head { background: #F8FAFC; border-bottom: 2px solid #E2E8F0; }
.table-head .table-cell { font-size: 11px; font-weight: 600; color: #64748B; }
.table-cell { font-size: 13px; color: #1E293B; padding: 8px 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
