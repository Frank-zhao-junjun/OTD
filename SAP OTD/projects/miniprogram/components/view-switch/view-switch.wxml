<!-- components/view-switch/view-switch.wxml -->
<view class="vs-wrap">
  <view
    class="vs-btn {{mode === 'card' ? 'vs-active' : ''}}"
    data-mode="card"
    bindtap="onSwitch"
  >
    <text>列</text>
  </view>
  <view
    class="vs-btn {{mode === 'table' ? 'vs-active' : ''}}"
    data-mode="table"
    bindtap="onSwitch"
  >
    <text>表</text>
  </view>
</view>
