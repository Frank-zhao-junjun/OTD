<!--pages/customers/customers.wxml -->
<view class="container">
  <view class="search-bar">
    <view class="search-input-wrap">
      <input class="search-input" placeholder="客户编号/名称" value="{{searchQuery}}" bindinput="onSearchInput" bindconfirm="onSearch"/>
    </view>
    <button class="search-btn primary-bg" bindtap="onSearch">查询</button>
    <button class="search-btn default" bindtap="onClear">重置</button>
  </view>

  <view class="toolbar">
    <view class="filter-hint"></view>
    <view-switch mode="{{viewMode}}" bind:change="onViewModeChange"/>
  </view>

  <view class="result-header" wx:if="{{totalCount > 0}}">
    <text class="result-count">共 {{totalCount}} 条记录</text>
  </view>

  <view wx:if="{{!loading && customers.length > 0 && viewMode === 'card'}}">
    <block wx:for="{{customers}}" wx:key="Customer">
      <view class="list-card">
        <view class="card-header">
          <text class="card-title">{{item.Customer}}</text>
        </view>
        <view class="card-body">
          <view class="card-row">
            <text class="card-label">名称</text>
            <text class="card-value">{{item.CustomerName || '-'}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">国家</text>
            <text class="card-value">{{item.Country || '-'}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">城市</text>
            <text class="card-value">{{item.CityName || '-'}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">行业</text>
            <text class="card-value">{{item.Industry || '-'}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 表格视图 -->
  <scroll-view scroll-x wx:if="{{!loading && customers.length > 0 && viewMode === 'table'}}" class="table-scroll">
    <view class="table-view">
      <view class="table-row table-head">
        <view class="table-cell" style="flex:1.5;">客户编号</view>
        <view class="table-cell" style="flex:2;">名称</view>
        <view class="table-cell">国家</view>
        <view class="table-cell" style="flex:1.5;">城市</view>
        <view class="table-cell" style="flex:1.5;">行业</view>
      </view>
      <view class="table-row" wx:for="{{customers}}" wx:key="Customer">
        <view class="table-cell" style="flex:1.5;">{{item.Customer}}</view>
        <view class="table-cell" style="flex:2;">{{item.CustomerName || '-'}}</view>
        <view class="table-cell">{{item.Country || '-'}}</view>
        <view class="table-cell" style="flex:1.5;">{{item.CityName || '-'}}</view>
        <view class="table-cell" style="flex:1.5;">{{item.Industry || '-'}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty-container" wx:if="{{!loading && customers.length === 0}}">
    <text class="empty-text">暂无客户数据</text>
  </view>
</view>
