/* pages/login/login.wxss */

.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1E3A5F 0%, #1E40AF 50%, #F8FAFC 50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── Header / Logo ──────────────────────────────────── */

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60px;
  padding-bottom: 40px;
}

.login-logo-icon {
  width: 72px;
  height: 72px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16px;
  border: 2px solid rgba(255, 255, 255, 0.2);
}

.login-title {
  font-size: 24px;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 4px;
}

.login-subtitle {
  font-size: 13px;
  color: #93C5FD;
}

/* ── Form ───────────────────────────────────────────── */

.login-form {
  width: calc(100% - 48px);
  max-width: 400px;
  background: #FFFFFF;
  border-radius: 12px;
  padding: 32px 24px 24px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
}

.form-item {
  margin-bottom: 20px;
}

.form-input-wrap {
  display: flex;
  align-items: center;
  background: #F8FAFC;
  border: 1px solid #E2E8F0;
  border-radius: 8px;
  padding: 0 12px;
  transition: border-color 0.2s;
}

.form-input-wrap:focus-within {
  border-color: #3B82F6;
  background: #FFFFFF;
}

.form-icon {
  font-size: 16px;
  margin-right: 8px;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  height: 44px;
  font-size: 15px;
  color: #1E293B;
  background: transparent;
}

.form-placeholder {
  color: #94A3B8;
}

.form-input-error {
  border-color: #EF4444;
}

.form-suffix {
  padding: 8px 0 8px 8px;
  font-size: 18px;
  flex-shrink: 0;
}

.form-error {
  font-size: 12px;
  color: #EF4444;
  margin-top: 4px;
  padding-left: 4px;
  display: block;
}

/* ── Captcha ─────────────────────────────────────────── */

.captcha-row {
  display: flex;
  gap: 12px;
}

.captcha-input-wrap {
  flex: 1;
}

.captcha-display {
  width: 120px;
  height: 44px;
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
  border: 1px solid #BFDBFE;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  cursor: pointer;
}

.captcha-text {
  font-size: 16px;
  font-weight: 700;
  color: #1E40AF;
  letter-spacing: 3px;
}

.captcha-hint {
  font-size: 10px;
  color: #64748B;
  margin-top: 1px;
}

/* ── Button ──────────────────────────────────────────── */

.login-btn {
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, #1E40AF, #2563EB);
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border-radius: 8px;
  border: none;
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.85;
}

.login-btn-disabled {
  opacity: 0.6;
}

/* ── Footer ──────────────────────────────────────────── */

.login-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20px;
  gap: 4px;
}

.login-footer-text {
  font-size: 13px;
  color: #94A3B8;
}

.login-footer-link {
  font-size: 13px;
  color: #3B82F6;
  font-weight: 500;
}
