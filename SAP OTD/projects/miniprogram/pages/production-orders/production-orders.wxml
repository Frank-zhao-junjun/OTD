<!--pages/production-orders/production-orders.wxml -->
<view class="container">
  <view class="search-bar">
    <view class="search-input-wrap">
      <input class="search-input" placeholder="订单号/物料编号" value="{{searchQuery}}" bindinput="onSearchInput" bindconfirm="onSearch"/>
    </view>
    <button class="search-btn primary-bg" bindtap="onSearch">查询</button>
    <button class="search-btn default" bindtap="onClear">重置</button>
  </view>

  <view class="toolbar">
    <view class="filter-hint"><text class="hint-text">默认工厂: {{plantFilter}}</text></view>
    <view-switch mode="{{viewMode}}" bind:change="onViewModeChange"/>
  </view>

  <view class="result-header" wx:if="{{totalCount > 0}}">
    <text class="result-count">共 {{totalCount}} 条记录</text>
  </view>

  <!-- 卡片 -->
  <view wx:if="{{!loading && orders.length > 0 && viewMode === 'card'}}">
    <block wx:for="{{orders}}" wx:key="ManufacturingOrder">
      <view class="list-card" data-id="{{item.ManufacturingOrder}}" bindtap="onViewDetail">
        <view class="card-header">
          <text class="card-title">{{item.ManufacturingOrder}}</text>
          <text class="card-badge" style="background-color: {{item.MfgOrderStatus === 'DLV' || item.MfgOrderStatus === 'TECO' ? '#DCFCE7' : item.MfgOrderStatus === 'REL' ? '#DBEAFE' : '#FEF3C7'}}; color: {{item.MfgOrderStatus === 'DLV' || item.MfgOrderStatus === 'TECO' ? '#166534' : item.MfgOrderStatus === 'REL' ? '#1E40AF' : '#92400E'}};">{{item.StatusText}}</text>
        </view>
        <view class="card-body">
          <view class="card-row"><text class="card-label">物料</text><text class="card-value">{{item.Material || '-'}}</text></view>
          <view class="card-row"><text class="card-label">工厂</text><text class="card-value">{{item.ProductionPlant || '-'}}</text></view>
          <view class="card-row"><text class="card-label">开始日期</text><text class="card-value">{{item.MfgOrderStartDate}}</text></view>
          <view class="card-row"><text class="card-label">计划数量</text><text class="card-value">{{item.MfgOrderPlannedTotalQty || '0'}} {{item.ProductionUnit || ''}}</text></view>
        </view>
      </view>
    </block>
  </view>

  <!-- 表格 -->
  <scroll-view scroll-x wx:if="{{!loading && orders.length > 0 && viewMode === 'table'}}" class="table-scroll">
    <view class="table-view">
      <view class="table-row table-head">
        <text class="table-cell w-order">订单号</text>
        <text class="table-cell w-type">物料</text>
        <text class="table-cell w-cust">工厂</text>
        <text class="table-cell w-date">开始日期</text>
        <text class="table-cell w-amt">计划量</text>
        <text class="table-cell w-status">状态</text>
      </view>
      <view class="table-row" wx:for="{{orders}}" wx:key="ManufacturingOrder" data-id="{{item.ManufacturingOrder}}" bindtap="onViewDetail">
        <text class="table-cell w-order">{{item.ManufacturingOrder}}</text>
        <text class="table-cell w-type">{{item.Material || '-'}}</text>
        <text class="table-cell w-cust">{{item.ProductionPlant || '-'}}</text>
        <text class="table-cell w-date">{{item.MfgOrderStartDate}}</text>
        <text class="table-cell w-amt">{{item.MfgOrderPlannedTotalQty || '0'}} {{item.ProductionUnit || ''}}</text>
        <text class="table-cell w-status">{{item.StatusText}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty-container" wx:if="{{!loading && orders.length === 0}}">
    <text class="empty-text">暂无生产订单数据</text>
  </view>
</view>
