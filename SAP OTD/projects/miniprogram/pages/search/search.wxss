/* pages/search/search.wxss */

.search-container {
  min-height: 100vh;
  background: #F8FAFC;
}

/* ── Search Bar ─────────────────────────────────────── */

.search-bar {
  display: flex;
  align-items: center;
  padding: 10px 12px;
  background: #FFFFFF;
  gap: 10px;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F1F5F9;
  border-radius: 20px;
  padding: 0 12px;
  height: 36px;
}

.search-icon {
  font-size: 14px;
  margin-right: 6px;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #1E293B;
  height: 36px;
}

.search-placeholder {
  color: #94A3B8;
}

.search-clear {
  font-size: 14px;
  color: #94A3B8;
  padding: 4px;
}

.search-cancel {
  font-size: 14px;
  color: #3B82F6;
  flex-shrink: 0;
}

/* ── Searching ──────────────────────────────────────── */

.search-status {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 0;
  gap: 10px;
}

.searching-spinner {
  width: 20px; height: 20px;
  border: 2px solid #E2E8F0;
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: srch-spin 0.6s linear infinite;
}

@keyframes srch-spin { to { transform: rotate(360deg); } }

.searching-text { font-size: 13px; color: #94A3B8; }

/* ── History ────────────────────────────────────────── */

.history-section {
  padding: 16px 12px;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.history-title {
  font-size: 13px;
  font-weight: 600;
  color: #64748B;
}

.history-clear {
  font-size: 12px;
  color: #94A3B8;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.history-tag {
  display: flex;
  align-items: center;
  background: #EFF6FF;
  border: 1px solid #BFDBFE;
  border-radius: 16px;
  padding: 6px 12px;
  gap: 6px;
}

.tag-text {
  font-size: 13px;
  color: #1E40AF;
}

.tag-close {
  font-size: 14px;
  color: #93C5FD;
  font-weight: 700;
  padding: 0 2px;
}

.history-empty {
  padding: 20px 0;
  text-align: center;
}

.empty-hint {
  font-size: 13px;
  color: #94A3B8;
}

/* ── Results ────────────────────────────────────────── */

.results-section {
  padding: 12px;
}

.result-group {
  margin-bottom: 16px;
}

.group-header {
  display: flex;
  align-items: center;
  padding: 8px 0;
  gap: 6px;
  border-bottom: 1px solid #F1F5F9;
  margin-bottom: 4px;
}

.group-icon { font-size: 14px; }
.group-name { font-size: 13px; font-weight: 600; color: #475569; }
.group-count { font-size: 12px; color: #94A3B8; }

.result-item {
  display: flex;
  align-items: center;
  padding: 12px 8px;
  border-bottom: 1px solid #F8FAFC;
  background: #FFFFFF;
  border-radius: 8px;
  margin-bottom: 2px;
}

.result-item:active {
  background: #F8FAFC;
}

.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.result-label {
  font-size: 14px;
  font-weight: 500;
  color: #1E293B;
}

.result-desc {
  font-size: 12px;
  color: #94A3B8;
  margin-top: 2px;
}

.result-arrow {
  font-size: 16px;
  color: #CBD5E1;
}

/* ── Empty ──────────────────────────────────────────── */

.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80px;
}

.empty-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.6; }
.empty-title { font-size: 15px; color: #475569; font-weight: 600; }
.empty-hint { font-size: 13px; color: #94A3B8; margin-top: 6px; }
