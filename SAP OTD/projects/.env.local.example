# OTD 助手 — 生产环境配置模板
# 复制为 .env.local 并填写实际值：cp .env.local.example .env.local

# ── 安全（必填）────────────────────────────────────────
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# 生产环境关闭公开注册（默认 production 已关闭，显式设置更安全）
ALLOW_REGISTRATION=false

# 对外访问地址（HTTPS 生产域名，Dashboard 内部回调用）
# APP_BASE_URL=https://otd.yourcompany.com

# 服务端口
DEPLOY_RUN_PORT=5000

# ── SAP S/4HANA 连接（必填）────────────────────────────
sapScheme=https
sapHost=your-tenant-api.s4hana.sapcloud.cn
sapClient=100
sapUsername=YOUR_SAP_COMM_USER
sapPassword='your-sap-password-with-special-chars'

# Mock 模式（仅开发/demo，生产必须为 false）
USE_MOCK=false

# ── 初始管理员（仅 seed-admin 脚本使用，不写入运行时）──
# ADMIN_USERNAME=admin
# ADMIN_INITIAL_PASSWORD=YourSecurePass123!
